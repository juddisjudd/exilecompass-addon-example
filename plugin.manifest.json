{
  "schemaVersion": "1.0",
  "id": "dev.juddisjudd.notes-addon",
  "name": "Notes Addon",
  "description": "Adds a lightweight notes panel for quick in-run reminders.",
  "author": "Judd",
  "homepage": "https://github.com/juddisjudd/exilecompass-addon-example",
  "version": "0.4.0",
  "kind": "addon",
  "entry": {
    "panel": "./dist/panel.js",
    "data": "./data/notes.default.json"
  },
  "compatibility": {
    "app": ">=0.1.0",
    "pluginApi": "^1.0.0"
  },
  "permissions": [
    "storage.read",
    "storage.write",
    "ui.panel"
  ],
  "contributions": {
    "data.providers": [
      {
        "type": "notes.seed",
        "source": "./notes.default.json",
        "label": "Default notes"
      }
    ],
    "view.panels": [
      {
        "id": "notes",
        "title": "Notes",
        "icon": "note",
        "pinDefault": false
      }
    ],
    "settings.sections": [
      {
        "id": "notes",
        "title": "Notes Addon",
        "order": 50
      }
    ],
    "actions.commands": [
      {
        "id": "notes-open",
        "title": "Open Notes",
        "description": "Focuses the notes panel."
      },
      {
        "id": "notes-clear-completed",
        "title": "Clear Completed Notes",
        "description": "Removes completed notes from the list."
      }
    ]
  }
}
